# ───────────────────────────────────────────────────────────────────────────
# EBHS Polymarket — environment variables
# Copy this file to ".env.local" and fill in the values from your Supabase
# project (Supabase Dashboard → Project Settings → API).
# ───────────────────────────────────────────────────────────────────────────

# Public (safe to expose to the browser) ------------------------------------
# Project URL, e.g. https://abcdefghijklmno.supabase.co
NEXT_PUBLIC_SUPABASE_URL=

# Public anon key (the "anon / public" key). RLS protects your data.
NEXT_PUBLIC_SUPABASE_ANON_KEY=

# Server-only (NEVER expose to the browser) ---------------------------------
# Service role key. Bypasses RLS. Used only by the seed script and the
# server-side signup route. Keep this secret.
SUPABASE_SERVICE_ROLE_KEY=

# The fake email domain usernames are mapped to (username -> username@ebhs.local).
# You normally do not need to change this.
NEXT_PUBLIC_EMAIL_DOMAIN=ebhs.local
